# --- ReconX Node Configuration ---
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# --- Security Credentials (REQUIRED) ---
# Generate secure keys using: openssl rand -base64 32
JWT_SECRET=reconx_tactical_secret_change_me
JWT_REFRESH_SECRET=reconx_tactical_refresh_change_me

# --- External Intelligence (REQUIRED) ---
# Get your key at: https://developer.shodan.io/
SHODAN_API_KEY=

# --- Optional Enrichment (Highly Recommended) ---
# https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=
# https://www.virustotal.com/
VIRUSTOTAL_API_KEY=

# --- Alert Routing (Optional) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=security@reconx.local

# --- Webhook Dispatch (Optional) ---
WEBHOOK_SECRET=reconx_webhook_hmac_secret
